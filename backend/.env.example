# The Odds API — get your key at https://the-odds-api.com
ODDS_API_KEY=your_odds_api_key_here

# How long (minutes) before cached odds are considered stale and re-fetched
# Free-plan-safe default:
# - selected sport pages may re-fetch after this window
# - the All Sports page stays cache-first
STALE_MINUTES=180

CORS_ORIGINS=http://localhost:5173
DB_PATH=sharpedge.db
FLASK_ENV=development
